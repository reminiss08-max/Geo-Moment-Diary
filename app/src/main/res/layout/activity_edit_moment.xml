<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="✏️ Edit Momen"
            android:textColor="@color/text_dark"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp"
            android:text="Perbarui cerita dan pengalamanmu"
            android:textColor="#777777"
            android:textSize="15sp" />

        <!-- Judul Momen -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Judul Momen"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etJudul"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/edittext_diary"
            android:hint="Masukkan judul momen"
            android:padding="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <!-- Cerita -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="📖 Cerita Momen"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCatatan"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/edittext_diary"
            android:gravity="top"
            android:hint="Tuliskan cerita momenmu..."
            android:padding="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <!-- Tombol Simpan -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSimpan"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/button_primary"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:text="🌸 SIMPAN PERUBAHAN"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>