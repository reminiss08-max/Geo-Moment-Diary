<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#FFF8EE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- FOTO -->

        <ImageView
            android:id="@+id/imgMoment"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"/>

        <!-- SEMUA INFORMASI -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="#FDE4EF"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Judul -->

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Judul Momen"
                android:textColor="#333333"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <!-- Cerita -->

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Isi cerita momen..."
                android:textColor="#555555"
                android:textSize="15sp"/>

            <!-- Garis -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"
                android:background="#F6BCD2"/>

            <!-- Tanggal -->

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 11 Juli 2026"
                android:textColor="#444444"
                android:textSize="15sp"/>

            <!-- Jam -->

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="🕒 01:56 WIB"
                android:textColor="#444444"
                android:textSize="15sp"/>

            <!-- Lokasi -->

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📍 Lokasi GPS Tersimpan ✓"
                android:textColor="#C96B8B"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Petunjuk -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="👉 Ketuk untuk melihat detail"
                android:textColor="#777777"
                android:textSize="14sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>